<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/11.0/phpunit.xsd" bootstrap="vendor/autoload.php" colors="true" processIsolation="false" stopOnFailure="false" cacheDirectory=".phpunit.cache">
  <coverage>
    <report>
      <clover outputFile="build/phpunit/logs/clover.xml"/>
      <crap4j outputFile="build/phpunit/logs/crap4j.xml"/>
      <html outputDirectory="build/phpunit/coverage"/>
      <text outputFile="php://stdout" showUncoveredFiles="false"/>
      <xml outputDirectory="build/phpunit/logs/coverage"/>
    </report>
  </coverage>
  <testsuites>
    <testsuite name="Feature">
      <directory suffix="Test.php">./tests/Feature</directory>
    </testsuite>
  </testsuites>
  <logging>
    <junit outputFile="build/phpunit/logs/junit.xml"/>
  </logging>
  <php>
    <server name="APP_ENV" value="testing"/>
    <server name="USE_LDAP" value="false"/>
    <server name="BCRYPT_ROUNDS" value="4"/>
    <server name="VAULT_PBKDF2_ITERATIONS" value="1"/>
    <server name="CACHE_DRIVER" value="array"/>
    <server name="DB_CONNECTION" value="sqlite"/>
    <server name="DB_DATABASE" value=":memory:"/>
    <server name="MAIL_DRIVER" value="array"/>
    <server name="QUEUE_CONNECTION" value="sync"/>
    <server name="SESSION_DRIVER" value="array"/>
  </php>
  <source>
    <include>
      <directory suffix=".php">./app</directory>
    </include>
  </source>
</phpunit>
